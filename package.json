{
  "name": "pihole-dns",
  "version": "1.0.0",
  "description": "Pi-hole v6 DNS Manager",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --inspect",
    "dist": "electron-builder --linux AppImage"
  },
  "build": {
    "appId": "com.jershbytes.pihole-dns",
    "productName": "Pi-hole DNS Manager",
    "files": [
      "src/**/*",
      "renderer/**/*",
      "assets/**/*",
      "package.json"
    ],
    "linux": {
      "target": "AppImage",
      "icon": "assets/pihole.png",
      "category": "Network"
    },
    "appImage": {
      "license": "LICENSE"
    }
  },
  "devDependencies": {
    "electron": "^41.0.0",
    "electron-builder": "^26.8.1"
  }
}
